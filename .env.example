GOOGLE_API_KEY=your_key_here

# LLM models — split to control cost
TRADINGAGENTS_DEEP_THINK_LLM=gemini-2.5-flash
TRADINGAGENTS_QUICK_THINK_LLM=gemini-2.5-flash

# Database
DATABASE_URL=sqlite:///./data/stockresearch.db

# Analysis date default (today minus this many days)
DEFAULT_DATE_OFFSET_DAYS=3

# Timeout for a single analysis run (seconds); 45 min default
ANALYSIS_TIMEOUT_SECONDS=2700

# Port exposed by Docker Compose
APP_PORT=8000

# Scheduled runs
SCHEDULE_TIMEZONE=America/New_York
SCHEDULE_RUN_HOUR=6

# Email delivery (leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
